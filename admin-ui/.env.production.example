# نمونه برای build و استقرار admin-ui (کپی به .env.production در CI یا سرور build)
# هرگز VITE_ENABLE_DEV_BYPASS=true یا VITE_USE_MSW=true نگذارید.

# آدرس پایهٔ API که مرورگر کاربر به آن درخواست می‌زند (مثلاً https://api.example.com)
# خالی بگذارید اگر همان origin + مسیر reverse proxy است.
VITE_API_URL=

# هاب Hamgit — در پرود معمولاً false یا حذف کنید مگر عمدی
VITE_FLAG_HAMGIT_PORT=false

# قراردادهای PR — مطابق نیاز محصول
VITE_FLAG_PR_CONTRACTS_PAGE=false

# Plane.so — مدیریت تسک سازمانی (برای فعال‌سازی در پروداکشن مقادیر را تکمیل کنید)
VITE_FLAG_PLANE_INTEGRATION=false
# VITE_PLANE_BASE_URL=https://api.plane.so
# VITE_PLANE_API_KEY=plane_api_your_key_here
# VITE_PLANE_WORKSPACE_SLUG=your-workspace-slug

# Sentry (اختیاری)
# VITE_SENTRY_DSN=
