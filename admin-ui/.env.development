# بارگذاری خودکار در `vite` / `npm run dev` (فقط development)
# ورود آزمایشی + مشاهدهٔ همهٔ صفحات بدون backend کامل؛ API از طریق proxy به mock یا بک‌اند واقعی

VITE_API_URL=
VITE_USE_MSW=false
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080
VITE_ENABLE_DEV_BYPASS=true
VITE_USE_CRM_API=true
VITE_DEV_USER_PERMISSIONS=*
VITE_DEV_USER_ID=mock-001
