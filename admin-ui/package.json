{
  "name": "amline-admin-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Admin UI for Amline Platform - اَملاین",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/assert-safe-production-env.mjs",
    "dev:e2e": "vite --mode e2e",
    "dev:local": "vite --port 3005 --strictPort",
    "build": "tsc && vite build",
    "verify": "npx tsc --noEmit && vitest run",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 500",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test accessibility-axe.spec.ts",
    "test:e2e:staging": "playwright test staging-admin-smoke.spec.ts --config=playwright.staging.config.ts",
    "test:e2e:staging:all": "playwright test tests/staging-admin-smoke.spec.ts tests/staging-full-routes.spec.ts --config=playwright.staging.config.ts"
  },
  "dependencies": {
    "@amline/ui-core": "*",
    "@sentry/react": "^8.55.1",
    "@tanstack/react-query": "^5.51.1",
    "axios": "^1.7.2",
    "axios-cookiejar-support": "^5.0.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.2.12",
    "jalaali-js": "^1.2.8",
    "jalali-react-datepicker": "^1.2.1",
    "lucide-react": "^0.408.0",
    "maplibre-gl": "^5.22.0",
    "posthog-js": "^1.364.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "react-router-dom": "^6.25.1",
    "recharts": "^2.12.7",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tough-cookie": "^4.1.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@amline/openapi-types": "*",
    "@axe-core/playwright": "^4.10.1",
    "@hookform/resolvers": "^3.9.0",
    "@playwright/test": "^1.58.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@types/jalaali-js": "^1.2.0",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.8",
    "fast-check": "^3.23.2",
    "jsdom": "^24.1.3",
    "msw": "^2.12.14",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
