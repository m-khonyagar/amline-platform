# پروفایل ۱: توسعه با MSW (بدون وابستگی به backend)
# - VITE_USE_MSW=true
# - VITE_ENABLE_DEV_BYPASS=true
# - VITE_API_URL را خالی بگذارید
#
# پروفایل ۲: اتصال به backend واقعی (FastAPI — پیش‌فرض املاین)
# - VITE_USE_MSW=false
# - VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080  (یا docker compose backend)
# - برای CRM پایگاه‌داده: VITE_USE_CRM_API=true و هدرهای dev زیر

# آدرس API (خالی = همان origin + Vite proxy)
VITE_API_URL=

# هم‌نام با amline-ui — وقتی ویزارد ادمین داخل Next embed است، در صورت خالی بودن VITE_API_URL
# از این‌ها به‌عنوان baseURL axios استفاده می‌شود (نیازی به کپی در admin-ui نیست مگر embed).
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080
# NEXT_PUBLIC_DEV_PROXY_TARGET=http://127.0.0.1:8080

# mock با MSW در dev — برای backend واقعی false بگذارید
VITE_USE_MSW=false

# هدف proxy — فقط /api/v1 و /financials به این آدرس فوروارد می‌شوند
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080

# CRM از /api/v1/crm/* (نیاز به crm:read/crm:write یا * در RBAC)
VITE_USE_CRM_API=true

# در dev، اگر AMLINE_RBAC_ENFORCE=1 روی backend باشد:
VITE_DEV_USER_PERMISSIONS=*
VITE_DEV_USER_ID=mock-001

# ورود آزمایشی — برای تست واقعی backend false بگذارید
VITE_ENABLE_DEV_BYPASS=false

# --- استیجینگ (بیلد production / Docker / GitHub Actions) ---
# VITE_API_URL=https://amline-backend-staging.darkube.app
# VITE_USE_MSW=false
# VITE_ENABLE_DEV_BYPASS=false
