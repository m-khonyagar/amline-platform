# Production build — admin-ui
# VITE_API_URL خالی = relative URL که از nginx proxy رد می‌شه (توصیه‌شده)
VITE_API_URL=

# هرگز true نگذارید در production
VITE_ENABLE_DEV_BYPASS=false
VITE_USE_MSW=false

# Feature flags
VITE_FLAG_HAMGIT_PORT=false
VITE_FLAG_PR_CONTRACTS_PAGE=false

# Plane.so integration (در پروداکشن با مقادیر واقعی پر کنید)
VITE_FLAG_PLANE_INTEGRATION=false
# VITE_PLANE_BASE_URL=https://api.plane.so
# VITE_PLANE_API_KEY=
# VITE_PLANE_WORKSPACE_SLUG=
