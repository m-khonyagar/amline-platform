# خالی = همان origin (در پرود nginx به backend پروکسی می‌کند). برای API مطلق در بیلد ست کنید.
VITE_API_URL=
# پروکسی dev — پیش‌فرض vite: http://127.0.0.1:8080 (مطابق mock)
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8080
# true = MSW محلی؛ برای اتصال به dev-mock-api یا backend واقعی false بگذارید
VITE_USE_MSW=false
