# کپی به `.env` و مقادیر را تنظیم کنید (uvicorn مستقیم .env را بارگذاری نمی‌کند —
# از `scripts/run-local-stack.ps1` در ریشهٔ ریپو استفاده کنید یا متغیرها را در shell بگذارید).

# Postgres محلی (Docker: پورت ممکن است 5432 یا 5433 باشد — با `docker port amline-postgres` چک کنید)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/amline

AMLINE_OTP_DEBUG=1
# لوکال/استیجینگ: شمارهٔ دمو + کد ثابت (پیش‌فرض 09107709601 / 11111) — در production معمولاً 0 یا حذف
AMLINE_OTP_MAGIC_ENABLED=1
AMLINE_RBAC_ENFORCE=0

# بازوها — توکن‌ها را از BotFather / پنل بله / ایتایار بگیرید
# وب‌هوک تلگرام: POST /api/v1/webhooks/telegram  (همچنین بدون پیشوند /api/v1 روی legacy mount)
# AMLINE_TELEGRAM_BOT_TOKEN=
# AMLINE_TELEGRAM_WEBHOOK_SECRET=   # همان مقدار secret_token در setWebhook
# AMLINE_BALE_BOT_TOKEN=
# AMLINE_BALE_WEBHOOK_SECRET=       # اختیاری؛ هدر X-Bale-Webhook-Secret
# AMLINE_EITAA_APP_TOKEN=
# AMLINE_EITAA_API_BASE=https://eitaayar.ir/api
# AMLINE_EITAA_WEBHOOK_SECRET=      # اختیاری
