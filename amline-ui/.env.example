# مقصد API در محیط dev (در نبود این مقدار، next.config.js مقدار localhost:8080 را استفاده می‌کند)
NEXT_PUBLIC_DEV_PROXY_TARGET=http://127.0.0.1:8080

# در صورت نیاز می‌توانید base را هم مستقیم تنظیم کنید
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# همان مقادیر بالا در زمان embed ویزارد admin-ui به‌عنوان baseURL درخواست‌های /api/v1 استفاده می‌شوند
# (اولویت: NEXT_PUBLIC_API_BASE_URL سپس NEXT_PUBLIC_DEV_PROXY_TARGET؛ در Vite standalone از VITE_API_URL استفاده کنید).

# ورود آزمایشی فقط برای توسعه محلی
NEXT_PUBLIC_ENABLE_DEV_BYPASS=false
