# ============================================================
# Amline — Production Environment Variables
# کپی این فایل به .env روی سرور و مقادیر را پر کنید
# ============================================================

APP_ENV=production

# ── Security (اجباری — حتماً عوض کنید) ─────────────────────
# openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=amline
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=amline

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── MinIO ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=amline
MINIO_SECRET_KEY=REPLACE_WITH_STRONG_PASSWORD

# ── Admin bootstrap ──────────────────────────────────────────
# شماره موبایل اولین ادمین — بعد از ورود موفق با OTP نقش Admin می‌گیرد (هم admin-ui هم app کاربر)
BOOTSTRAP_ADMIN_MOBILE=09100000000

# OTP ثابت فقط برای دمو/تست روی سرور واقعی — در محیط پرترافیک حتماً false بگذارید
AMLINE_FIXED_TEST_OTP_ENABLED=false
AMLINE_FIXED_TEST_MOBILE=09100000000
AMLINE_FIXED_TEST_OTP=11111

# OTP جادویی (شماره/کد ثابت، بدون SMS) — در production معمولاً خاموش بماند
# AMLINE_OTP_MAGIC_ENABLED=0
# اگر برای دمو مجبورید روشن کنید: AMLINE_OTP_MAGIC_ENABLED=1 و در صورت نیاز AMLINE_OTP_MAGIC_MOBILE / AMLINE_OTP_MAGIC_CODE

# ── CORS ─────────────────────────────────────────────────────
# دامنه‌های frontend خود را با کاما جدا کنید
CORS_ORIGINS=https://admin.amline.ir,https://app.amline.ir,https://consultant.amline.ir

# ── SMS — برای OTP واقعی (اجباری برای production) ───────────
# از https://kavenegar.com دریافت کنید
KAVENEGAR_API_KEY=REPLACE_WITH_KAVENEGAR_API_KEY
# نام template OTP در پنل Kavenegar (اختیاری — اگر خالی باشد پیامک ساده ارسال می‌شود)
KAVENEGAR_OTP_TEMPLATE=

# ── PDF Generator ────────────────────────────────────────────
# در Docker Compose خودکار تنظیم می‌شود
AMLINE_PDF_GENERATOR_URL=http://pdf-generator:8000

# ── درگاه پرداخت (اختیاری) ───────────────────────────────────
ZARINPAL_TOKEN=
ZARINPAL_CALL_BACK_URL=https://app.amline.ir/payment/result

# ── AI (اختیاری) ─────────────────────────────────────────────
OPENAI_API_KEY=
AMLINE_AI_URL=
