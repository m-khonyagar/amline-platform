# Copy to .env in repo root (gitignored). Never commit real values.

# Arvan: https://npanel.arvancloud.ir/profile/api-keys
ARVAN_API_KEY=Apikey xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Staging VPS (SSH)
DEPLOY_HOST=212.80.24.109
DEPLOY_USER=root
DEPLOY_PASSWORD=
# یا به‌جای رمز: مسیر کلید خصوصی روی همین PC (نه خط ssh-ed25519 AAA... که عمومی است)
# DEPLOY_SSH_KEY=C:\Users\You\.ssh\id_ed25519
# DEPLOY_SSH_KEY_PASSPHRASE=

# STAGING_API_URL=https://api.amline.ir
# STAGING_API_CONNECT_IP=212.80.24.56   # اختیاری؛ برای api.amline.ir از repo پر می‌شود
# STAGING_API_DISABLE_CONNECT_IP=1      # اجبار به dial به نام دامنه (بدون IP)
# STAGING_CADDY_STRIP_API_V1_PREFIX=1   # پیش‌فرض: /api/v1/* → upstream بدون پیشوند (سازگار با api.amline.ir)
# STAGING_SAME_ORIGIN_API=1   # پیش‌فرض: پروکسی /api روی Caddy. 0 = axios مستقیم به STAGING_API_URL

# ── Backend (docker compose روی سرور استیجینگ) ─────────────────
# ورود/امضای دمو بدون SMS برای شمارهٔ پیش‌فرض (۱۱۱۱۱) — در کد با AMLINE_OTP_MAGIC_* قابل تغییر است
AMLINE_OTP_MAGIC_ENABLED=1

# Optional
# STAGING_A_IP=212.80.24.109
# ARVAN_DOMAIN=amline.ir
# SKIP_BUILD=1
# ENABLE_CADDY=1
# CADDY_TLS_INTERNAL=1   # only if DNS not ready; default = public Let's Encrypt
